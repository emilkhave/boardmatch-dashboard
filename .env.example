# BoardMatch — environment variables
# Copy to .env.local for local dev (never commit real values — .env* is gitignored).
# In production these live in Vercel → Settings → Environment Variables.
#
# Two kinds:
#   VITE_*  → baked into the browser build. Safe to expose (public by design).
#   others  → server-only (Vercel serverless functions). NEVER prefix with VITE_.

# ── Supabase: client (browser) ───────────────────────────────────────────────
# From Supabase → Settings → API. The anon key is public; security is enforced by
# Supabase Auth + row-level security, not by hiding it.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Admin allowlist (browser) ────────────────────────────────────────────────
# Comma-separated emails that get the ADMIN workspace. Everyone else who signs up
# is a company. Not a secret — it only decides which UI to route to.
VITE_ADMIN_EMAILS=have@thehatchpartners.com

# ── Supabase: server (serverless functions) ──────────────────────────────────
# From Supabase → Settings → API. The service_role key bypasses RLS — SERVER ONLY.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Zoho CRM (server) — optional, set up later ───────────────────────────────
# See ZOHO_SETUP.md. Leave blank until you connect Zoho.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# EU account by default; only set these if you're on a non-EU Zoho data center.
# ZOHO_ACCOUNTS_DOMAIN=https://accounts.zoho.eu
# ZOHO_API_DOMAIN=https://www.zohoapis.eu
ZOHO_MODULE=Leads
ZOHO_EMAIL_FIELD=Email
# Optional JSON overriding Zoho field API names → our fields.
# ZOHO_FIELD_MAP=
# Secret token gating the manual /api/zoho-sync and /api/zoho-test endpoints.
ZOHO_TEST_TOKEN=
